COMPANY_NEWS_USE_AI=1
LLM_PROVIDER=claude-cli

# 日志级别：INFO 打印数据源和 AI 摘要；DEBUG 额外打印完整 prompt 和原始响应
# LOG_LEVEL=INFO

# Claude CLI
# 直接复用你本机已配置好的 Claude Code CLI。
# 默认命令就是 claude，一般不需要改。
# CLAUDE_CLI_COMMAND=claude
# CLAUDE_CLI_TIMEOUT_SECONDS=120

# OpenAI-compatible
# OPENAI_API_KEY=your_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# Anthropic / Claude
ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint

# Benzinga News
# BENZINGA_API_KEY=your_benzinga_api_key

# IP 限速（滑动窗口）
# RATE_LIMIT_REQUESTS=10        每个 IP 在窗口内允许的最大请求次数，设为 0 关闭限速
# RATE_LIMIT_WINDOW_SECONDS=86400   窗口大小，默认 86400 秒（24 小时）
